# Tal'ah staging environment profile.
NODE_ENV=staging
DATABASE_URL=postgresql://STAGING_USER:STAGING_PASSWORD@STAGING_HOST:5432/talah_staging
JWT_SECRET=replace-with-staging-random-32-byte-secret
ADMIN_PIN_HASH=$2a$12$replaceWithStagingBcryptHash
EXPO_ACCESS_TOKEN=expo_replace_with_staging_token
PORT=3000
CORS_ORIGIN=https://staging.example.replit.app
