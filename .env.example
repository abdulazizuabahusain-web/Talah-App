# Tal'ah environment example. Copy to your local secret store and replace placeholders.
# Never commit real secrets or production credentials.

# Runtime mode. Use NODE_ENV=staging in the staging profile and NODE_ENV=production in production.
NODE_ENV=staging

# PostgreSQL connection string used by @workspace/db and Drizzle.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/talah

# Legacy JWT-style shared secret placeholder for integrations that expect one.
# Current admin sessions use ADMIN_SESSION_SECRET / ADMIN_PIN_HASH instead.
JWT_SECRET=replace-with-random-32-byte-secret

# Optional dedicated signing secret for stateless admin dashboard tokens.
ADMIN_SESSION_SECRET=replace-with-random-32-byte-secret

# Bcrypt hash of the admin PIN. Required in production.
# Generate with: node -e "const b=require('bcryptjs');console.log(b.hashSync('YOUR_PIN',12))"
ADMIN_PIN_HASH=$2a$12$replaceWithRealBcryptHash

# API server port. Replit usually injects this automatically.
PORT=3000

# Comma-separated CORS allowlist for production API requests.
# Example: https://your-app.replit.app,https://admin.example.com
CORS_ORIGINS=https://example.com

# Backward-compatible single-origin placeholder for external tooling.
# Prefer CORS_ORIGINS in application config.
CORS_ORIGIN=https://example.com

# Pino log level: trace, debug, info, warn, error, or fatal.
LOG_LEVEL=info

# GitHub token used by admin sync-status and Replit post-merge sync.
GITHUB_PAT=ghp_replace_with_pat

# GitHub PAT expiry date in YYYY-MM-DD format for warnings/status UI.
PAT_EXPIRES_AT=2026-12-31

# Expo access token for EAS/Expo automation if enabled.
EXPO_ACCESS_TOKEN=expo_replace_with_token

# Mobile/API base URL overrides for Expo web/native previews.
EXPO_PUBLIC_API_BASE=https://example.com/api
EXPO_PUBLIC_DOMAIN=example.com

# Replit domains injected by Replit deployments/previews.
REPLIT_DEV_DOMAIN=example.replit.dev
REPLIT_INTERNAL_APP_DOMAIN=example.replit.app

# Analytics token. Optional until Mixpanel is wired in the runtime.
MIXPANEL_TOKEN=replace-with-mixpanel-token

# Sentry DSN. Optional until Sentry is wired in the runtime.
SENTRY_DSN=https://public@example.ingest.sentry.io/project

# GitHub Actions deployment webhook notes:
# REPLIT_DEPLOY_WEBHOOK must be configured as a GitHub Actions secret, never in this file.
# REPLIT_STAGING_DEPLOY_WEBHOOK must be configured as a GitHub Actions secret, never in this file.
