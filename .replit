# Environment separation strategy:
# - Keep deploymentTarget = "autoscale" for both Tal'ah deployments.
# - Staging and production are separate Replit Autoscale deployments/projects,
#   each with its own Replit Secrets profile and PostgreSQL 16 DATABASE_URL.
# - The staging deployment must set NODE_ENV=staging and use the
#   .env.staging.example placeholders as its checklist.
# - The production deployment must set NODE_ENV=production and use the
#   .env.production.example placeholders as its checklist.
# - Never point staging at the production DATABASE_URL or reuse production
#   JWT_SECRET, ADMIN_PIN_HASH, EXPO_ACCESS_TOKEN, or CORS_ORIGIN values.

modules = ["nodejs-24", "postgresql-16", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 8083
externalPort = 4200

[[ports]]
localPort = 20433
externalPort = 3000

[[ports]]
localPort = 20434
externalPort = 3002

[[ports]]
localPort = 23744
externalPort = 3003

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PAT_EXPIRES_AT = "2026-06-02"
