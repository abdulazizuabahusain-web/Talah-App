# Tal'ah production environment profile.
NODE_ENV=production
DATABASE_URL=postgresql://PRODUCTION_USER:PRODUCTION_PASSWORD@PRODUCTION_HOST:5432/talah_production
JWT_SECRET=replace-with-production-random-32-byte-secret
ADMIN_PIN_HASH=$2a$12$replaceWithProductionBcryptHash
EXPO_ACCESS_TOKEN=expo_replace_with_production_token
PORT=3000
CORS_ORIGIN=https://production.example.replit.app
